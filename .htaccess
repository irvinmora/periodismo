# Activar mod_rewrite
RewriteEngine On
RewriteBase /

# ─── URLs limpias ────────────────────────────────────────────────
# /noticias/8  →  noticia_completa.php?id=8
RewriteRule ^noticias/([0-9]+)/?$  noticia_completa.php?id=$1 [QSA,L]

# /secciones  →  secciones.php
RewriteRule ^secciones/?$  secciones.php [QSA,L]

# ─── Servir archivos y carpetas reales directamente ──────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ─── Seguridad ───────────────────────────────────────────────────
# Bloquear archivos sensibles
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|env)$">
    Require all denied
</FilesMatch>

# Bloquear acceso directo a carpetas internas
RedirectMatch 403 ^/(config|includes)/

# Desactivar listado de directorios
Options -Indexes

# Protección básica contra hotlink de imágenes
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?localhost [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?irvinmora [NC]
RewriteRule \.(jpg|jpeg|png|gif)$ - [F]

# ─── Rendimiento ─────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType text/css   "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>